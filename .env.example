APP_ENV=development

# AWS Bedrock (LLM)
# Leave AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/AWS_SESSION_TOKEN blank if
# running on an EC2 instance whose IAM role already has Bedrock access —
# boto3 picks that up automatically. Only set them if running elsewhere.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# storage
DATABASE_PATH=./db/app.db
JOBS_STORAGE_DIR=../data/jobs

# recruiter auth
RECRUITER_EMAIL=recruiter@seclore.com
RECRUITER_PASSWORD=seclore123

# candidate auth
SCREENING_LINK_TTL_MINUTES=15
FRONTEND_BASE_URL=http://localhost:3000

# screening conversation bounds
MAX_PROFILE_FOLLOWUPS=2
MAX_SECLORE_QA_TURNS=5

# RAG
KNOWLEDGE_BASE_DIR=../data/knowledge_base
RAG_TOP_K=3

# CORS / frontend
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
