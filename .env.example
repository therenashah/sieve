APP_ENV=development

# LLM
LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY is unused in normal operation now that client.py calls Claude
# via AWS Bedrock (auth comes from the EC2 instance's IAM role). Only needed if
# you add a direct-API local-dev fallback later.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AWS_REGION=us-east-1

# storage
DATABASE_PATH=./db/sieve.db

# candidate auth
SCREENING_LINK_TTL_MINUTES=15

# CORS / frontend
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
